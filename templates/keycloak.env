# Database (shared DO managed PostgreSQL cluster, separate database)
KC_DB=postgres
KC_DB_URL=jdbc:postgresql://${POSTGRES_DB_HOST}:25060/keycloak?ssl=true&sslmode=require
KC_DB_USERNAME=keycloak
KC_DB_PASSWORD=${KEYCLOAK_DB_PASSWORD}

# Hostname and reverse proxy
# KC_PROXY_HEADERS tells Keycloak to trust X-Forwarded-* headers from nginx.
KC_HOSTNAME=auth.${SERVER_DOMAIN}
KC_PROXY_HEADERS=xforwarded
KC_HTTP_ENABLED=true

# Initial admin credentials — only used on first boot to seed the admin account.
# You can change the password in the admin UI afterward.
KEYCLOAK_ADMIN=${APP_NAME}
KEYCLOAK_ADMIN_PASSWORD=${KEYCLOAK_ADMIN_PASSWORD}
